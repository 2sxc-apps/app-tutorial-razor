@inherits Custom.Hybrid.RazorTyped
@using ToSic.Razor.Blade

@* Make sure anonymous users have the 2sxc JS API *@
@Kit.Page.Activate("2sxc.JsCore")

<script>
  const specsQuerySelectDemo = {
    moduleId: @MyContext.Module.Id,
    outputId: "query-select-output-@UniqueKey",
    stream: "Authors"
  };
</script>

<button type="button" class="btn btn-primary"
  onclick="window.tutQueryOdata.load(specsQuerySelectDemo)">
  Load query results
</button>

<button type="button" class="btn btn-primary"
  onclick="window.tutQueryOdata.load({
    ...specsQuerySelectDemo,
    '$select': &quot;FirstName,LastName,Birthday&quot;
  })">
  Load with $select
</button>

<div style="overflow-x:auto;" id="query-select-output-@UniqueKey">
  <code></code>
  <br />
  <table style="width:100%; border-collapse:collapse;" class="table">
    <thead></thead>
    <tbody></tbody>
  </table>
</div>

<script src="@App.Folder.Url/tutorials/js-data/js/get-query-odata.js" @Kit.Page.AssetAttributes()></script>