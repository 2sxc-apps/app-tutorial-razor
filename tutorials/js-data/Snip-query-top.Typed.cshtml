@inherits Custom.Hybrid.RazorTyped
@using ToSic.Razor.Blade

@Kit.Page.Activate("2sxc.JsCore")

<script>
  const specsQueryTopDemo = {
    moduleId: @MyContext.Module.Id,
    outputId: "query-top-output-@UniqueKey",
    stream: "Authors"
  };
</script>

<button type="button" class="btn btn-primary"
  onclick="window.tutQueryOdata.load(specsQueryTopDemo)">
  Load query results
</button>

<button type="button" class="btn btn-primary"
  onclick="window.tutQueryOdata.load({
    ...specsQueryTopDemo,
    '$top': 3
  })">
  Load with $top
</button>

<div style="overflow-x:auto;" id="query-top-output-@UniqueKey">
  <code></code><br />
  <table style="width:100%; border-collapse:collapse;" class="table">
    <thead></thead>
    <tbody></tbody>
  </table>
</div>

<script src="@App.Folder.Url/tutorials/js-data/js/get-query-odata.js" @Kit.Page.AssetAttributes()></script>