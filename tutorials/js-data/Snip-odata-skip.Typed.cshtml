@inherits Custom.Hybrid.RazorTyped
@using ToSic.Razor.Blade

@* Make sure anonymous users have the 2sxc JS API *@
@Kit.Page.Activate("2sxc.JsCore")

<script>
  const specsSkipDemo = {
    moduleId: @MyContext.Module.Id,
    outputId: "skip-output-@UniqueKey"
  };
</script>

<button type="button" class="btn btn-primary"
  onclick="window.tutOdata.load({ ...specsSkipDemo, $orderby: 'Name', $skip: 2 })">
  Skip first 2 poets
</button>

<button type="button" class="btn btn-primary"
  onclick="window.tutOdata.load({ ...specsSkipDemo, $orderby: 'Name', $skip: 2, $top: 2 })">
  Skip 2 and take 2
</button>

<div id="skip-output-@UniqueKey">
  <code></code>
  <br />
  <table class="table">
    <thead></thead>
    <tbody></tbody>
  </table>
</div>

<script src="@App.Folder.Url/tutorials/js-data/js/get-data-odata.js" @Kit.Page.AssetAttributes()></script>